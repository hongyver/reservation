# 고양시 체육시설 예약 설정 예시
# 이 파일을 복사해서 .env 로 만드세요: cp .env.example .env
# ============================================================


# ============================================================
# [A] 다중 계정 모드 — launch.py 사용
#     python3 launch.py
# ============================================================
# 계정 번호(N)는 1부터 시작, 중간에 빠져도 됩니다.
# ID/PW가 있는 번호만 실행됩니다.

# ── 계정 1 ──────────────────────────────────────────────────
TENNIS_ACCOUNT_1_ID=user1
TENNIS_ACCOUNT_1_PW=pass1
# 예약 방법 2: 날짜:시간:코트 (여러 건 가능)
TENNIS_ACCOUNT_1_RESERVATION_1=2026-06-07:10:1
TENNIS_ACCOUNT_1_RESERVATION_2=2026-06-07:08:2

# ── 계정 2 ──────────────────────────────────────────────────
TENNIS_ACCOUNT_2_ID=user2
TENNIS_ACCOUNT_2_PW=pass2
TENNIS_ACCOUNT_2_RESERVATION_1=2026-06-14:10:3

# ── 계정 3 (예약 방법 1: 날짜+시간+코트 조합) ────────────────
# TENNIS_ACCOUNT_3_ID=user3
# TENNIS_ACCOUNT_3_PW=pass3
# TENNIS_ACCOUNT_3_DATES=2026-06-07,2026-06-14
# TENNIS_ACCOUNT_3_HOURS=8,10
# TENNIS_ACCOUNT_3_COURT=4

# ── 계정 4 (예약 방법 3: 코트별 시간대) ──────────────────────
# TENNIS_ACCOUNT_4_ID=user4
# TENNIS_ACCOUNT_4_PW=pass4
# TENNIS_ACCOUNT_4_DATES=2026-06-07
# TENNIS_ACCOUNT_4_COURT_1_HOURS=8,10
# TENNIS_ACCOUNT_4_COURT_2_HOURS=12,14


# ============================================================
# [B] 단일 계정 모드 — python3 main.py 직접 실행 (기존 방식)
#     [A] 설정이 없을 때만 사용됩니다.
# ============================================================

# TENNIS_USER_ID=your_id_here
# TENNIS_USER_PW=your_password_here

# 예약 방법 2: 날짜:시간:코트
# TENNIS_RESERVATION_1=2026-06-07:10:1
# TENNIS_RESERVATION_2=2026-06-07:08:2

# 예약 방법 1: 날짜+시간+코트
# TENNIS_DATES=2026-06-07
# TENNIS_HOURS=8,10
# TENNIS_COURT=1

# 예약 방법 3: 코트별 시간
# TENNIS_DATES=2026-06-07
# TENNIS_COURT_1_HOURS=8,10
# TENNIS_COURT_2_HOURS=12,14


# ============================================================
# 공통 실행 설정 (선택 — 미설정 시 기본값 사용)
# ============================================================

# 예약 오픈 시간
# TENNIS_RESERVATION_DAY=25    # 매월 25일 (0 = 즉시 실행)
# TENNIS_RESERVATION_HOUR=10   # 10시
# TENNIS_RESERVATION_MINUTE=0  # 0분

# API 서버 포트 (api_server.py)
# API_PORT=5000
# API_HOST=0.0.0.0
